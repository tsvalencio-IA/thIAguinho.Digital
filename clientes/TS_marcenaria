                let mensagens = [];
                
                // Se tiver imagem, tenta usar o modelo de visão, senão, modelo normal de texto
                let modeloSelecionado = "llama-3.3-70b-versatile"; 

                if (base64ImagemGlobal) {
                    modeloSelecionado = "llama-3.2-11b-vision-preview";
                    mensagens = [
                        {
                            role: "user",
                            content: [
                                { type: "text", text: promptComando },
                                { type: "image_url", image_url: { url: base64ImagemGlobal } }
                            ]
                        }
                    ];
                } else {
                    mensagens = [{ role: "user", content: promptComando }];
                }

                let projetoIA = null;

                try {
                    const resposta = await fetch("https://api.groq.com/openai/v1/chat/completions", {
                        method: 'POST',
                        headers: { "Authorization": `Bearer ${currentApiKey}`, "Content-Type": "application/json" },
                        body: JSON.stringify({
                            model: modeloSelecionado, 
                            messages: mensagens,
                            response_format: { type: "json_object" }, 
                            temperature: 0.1 // Temperatura baixa para focar em matemática exata
                        })
                    });

                    const dados = await resposta.json();
                    if (!resposta.ok) {
                        throw new Error(dados.error?.message || "Erro desconhecido na API.");
                    }
                    projetoIA = JSON.parse(dados.choices[0].message.content);
                } catch (err) { 
                    console.error("Falha na chamada principal da IA:", err);
                    // Fallback para modelo básico se o vision falhar ou cota exceder
                    if (base64ImagemGlobal) {
                        alert("O modelo de Visão falhou. Tentando apenas com o texto...");
                        const fallbackReq = await fetch("https://api.groq.com/openai/v1/chat/completions", {
                            method: 'POST',
                            headers: { "Authorization": `Bearer ${currentApiKey}`, "Content-Type": "application/json" },
                            body: JSON.stringify({
