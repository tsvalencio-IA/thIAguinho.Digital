                                messages: [{ role: "user", content: promptComando }],
                                response_format: { type: "json_object" }, temperature: 0.1
                            })
                        });
                        const dadosFB = await fallbackReq.json();
                        projetoIA = JSON.parse(dadosFB.choices[0].message.content);
                    } else {
                        throw err;
                    }
                }

                if (!projetoIA) throw new Error("A Inteligência Artificial não conseguiu estruturar os dados. Tente novamente.");

                // 1. Tabela e Textos
                const textoRelatorio = `
${projetoIA.descricao_projeto}

🔍 **Engenharia de Ferragens Calculada:**
- Dobradiças: ${projetoIA.ferragens_reais?.dobradicas || 0} unidades
- Corrediças: ${projetoIA.ferragens_reais?.corredicas_pares || 0} pares
- Puxadores: ${projetoIA.ferragens_reais?.puxadores || 0} unidades
- Parafusos: ${projetoIA.ferragens_reais?.parafusos || 0} unidades aproximadas.
                `;
                document.getElementById('descricaoProjeto').innerHTML = textoRelatorio.replace(/\n/g, '<br>');
                
                const tbody = document.getElementById('tabelaPlanoCorte');
                tbody.innerHTML = '';
                if(projetoIA.plano_de_corte) {
                    projetoIA.plano_de_corte.forEach(peca => {
                        tbody.innerHTML += `
                            <tr>
                                <td><strong>${peca.peca}</strong></td>
                                <td>${peca.qtde}</td>
                                <td>${peca.comprimento}</td>
                                <td>${peca.largura}</td>
                                <td style="color: var(--secondary-wood); font-weight:600;">${peca.espessura}</td>
                                <td><span style="background:var(--bg-light-panel); padding:4px 8px; border-radius:4px; font-size:0.85em;">${peca.fita_borda}</span></td>
                            </tr>
                        `;
                    });
                }

                // 2. Orçamento (Inputs da seção 4 preenchidos automaticamente)
                document.getElementById('itemName').value = projetoIA.nome_projeto || "Móvel Inteligente";
                if(projetoIA.custos) {
                    document.getElementById('costMaterial').value = projetoIA.custos.material || 0;
                    document.getElementById('costLabor').value = projetoIA.custos.mao_de_obra || 0;
                    document.getElementById('costHardware').value = projetoIA.custos.ferragens || 0;
                    document.getElementById('costOther').value = projetoIA.custos.outros || 0;
                    calcularTotal();
                }

                // 3. INICIAR 3D APENAS APÓS A TELA FICAR VISÍVEL
                if (!motor3DIniciado) {
                    init3D();
                    motor3DIniciado = true;
                }
                
                const med = projetoIA.dimensoes_mm || { largura: 1000, altura: 800, profundidade: 500 };
                const est = projetoIA.estrutura || { portas: 0, gavetas: 0 };
                
                setTimeout(() => {
                    ajustarTamanho3D();
                    // Agora chamamos o construtor paramétrico que lê portas e gavetas!
                    desenharMovelParametrico(med.largura, med.altura, med.profundidade, est.portas, est.gavetas);
                }, 100);

            } catch(erro) {
                alert("Erro ao processar: " + erro.message);
            } finally {
                const botaoGerar = document.getElementById('processAudioBtn');
                botaoGerar.innerHTML = '<i class="fas fa-magic"></i> Analisar com IA e Gerar 3D';
                botaoGerar.disabled = false;
            }
        }

        // ==========================================
        // MOTOR 3D PROFISSIONAL E INTERATIVO
        // ==========================================
        function init3D() {
            const container = document.getElementById('visualizador3D');
            const wrapper = document.getElementById('container3DWrapper');
            
            cena3D = new THREE.Scene();

            const luzAmbiente = new THREE.AmbientLight(0xffffff, 0.7);
            cena3D.add(luzAmbiente);
            
            const luzSpot = new THREE.DirectionalLight(0xffffff, 1.0);
            luzSpot.position.set(5, 10, 5);
            cena3D.add(luzSpot);

            // Luz suave lateral para volume
            const luzTras = new THREE.DirectionalLight(0xDDA15E, 0.4); 
            luzTras.position.set(-5, 5, -5);
            cena3D.add(luzTras);

            camera3D = new THREE.PerspectiveCamera(45, wrapper.clientWidth / wrapper.clientHeight, 0.1, 1000);
            
            renderizador3D = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderizador3D.setPixelRatio(Math.min(window.devicePixelRatio, 2)); 
            renderizador3D.setSize(wrapper.clientWidth, wrapper.clientHeight);
            container.appendChild(renderizador3D.domElement);

            controles3D = new THREE.OrbitControls(camera3D, renderizador3D.domElement);
            controles3D.enableDamping = true;
            controles3D.dampingFactor = 0.05;

            const gridHelper = new THREE.GridHelper(10, 20, 0xC6B6A5, 0xEFEAE5);
            gridHelper.position.y = -0.01;
            cena3D.add(gridHelper);

            // EVENTO DE CLIQUE PARA INTERATIVIDADE (Raycaster)
            renderizador3D.domElement.addEventListener('pointerdown', onClick3D, false);

            function animar() {
                requestAnimationFrame(animar);
                
                // Animação Paramétrica (Abre gavetas e portas suavemente)
                if (grupoMovelAtual) {
                    grupoMovelAtual.children.forEach(filho => {
                        const data = filho.userData;
                        if (!data) return;
                        
                        const vel = 0.1; // Velocidade da animação

                        if (data.tipo === 'porta') {
                            const alvo = data.aberto ? data.rotacaoAberta : data.rotacaoFechada;
                            filho.rotation.y += (alvo - filho.rotation.y) * vel;
                        } 
                        else if (data.tipo === 'gaveta') {
                            const alvoZ = data.aberto ? data.posAberta : data.posFechada;
                            filho.position.z += (alvoZ - filho.position.z) * vel;
                        }
                    });
                }

                controles3D.update();
                renderizador3D.render(cena3D, camera3D);
            }
            animar();

            window.addEventListener('resize', ajustarTamanho3D);
        }

        function ajustarTamanho3D() {
            if(!camera3D || !renderizador3D) return;
            const wrapper = document.getElementById('container3DWrapper');
            if(wrapper.clientWidth === 0) return; 
            
            camera3D.aspect = wrapper.clientWidth / wrapper.clientHeight;
            camera3D.updateProjectionMatrix();
            renderizador3D.setSize(wrapper.clientWidth, wrapper.clientHeight);
        }

        // LÓGICA DE CLIQUE NO 3D
        function onClick3D(event) {
            const rect = renderizador3D.domElement.getBoundingClientRect();
            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

            raycaster.setFromCamera(mouse, camera3D);

            const intersects = raycaster.intersectObjects(objetosInterativos, false);
            
            if (intersects.length > 0) {
                // Ao invés de pegar a malha (chapa), pegamos o PAI (o Pivot da Porta ou o Grupo da Gaveta)
                const malhaClicada = intersects[0].object;
                const grupoAnimavel = malhaClicada.userData.grupoPai;
                
                if (grupoAnimavel) {
                    grupoAnimavel.userData.aberto = !grupoAnimavel.userData.aberto;
                }
            }
        }

        // CONSTRUTOR PARAMÉTRICO DE QUALQUER MÓVEL
        function desenharMovelParametrico(largura_mm, altura_mm, profundidade_mm, numPortas, numGavetas) {
            if (grupoMovelAtual) cena3D.remove(grupoMovelAtual);
            objetosInterativos = []; // Limpa objetos clicáveis antigos

            grupoMovelAtual = new THREE.Group();
            cena3D.add(grupoMovelAtual);

            // Conversão para metros no Three.js
            const L = largura_mm / 1000;
            const A = altura_mm / 1000;
            const P = profundidade_mm / 1000;
            const E = 0.015; // Espessura do MDF 15mm
            const F = 0.003; // Folga de 3mm entre frentes

            // Paleta Oficial thIAguinho
            const matMDFClaro = new THREE.MeshStandardMaterial({ color: 0xFDFCF9, roughness: 0.8 }); // --light-cream
            const matMDFMadeira = new THREE.MeshStandardMaterial({ color: 0x7F5539, roughness: 0.9 }); // --secondary-wood
            const matPuxador = new THREE.MeshStandardMaterial({ color: 0x4A3C30, metalness: 0.6, roughness: 0.4 }); // --primary-dark
            
            // Materiais mesclados para simular a borda
            const matBordaMDF = new THREE.MeshStandardMaterial({ color: 0xEFEAE5, roughness: 0.9 });
            const materiaisChapa = [matBordaMDF, matBordaMDF, matMDFClaro, matMDFClaro, matBordaMDF, matBordaMDF];
            const materiaisPorta = [matBordaMDF, matBordaMDF, matMDFMadeira, matMDFClaro, matBordaMDF, matBordaMDF]; // Frente madeira, interno claro

            function criarChapa(larg, alt, prof, materiais, x, y, z, interativo = false) {
                const geo = new THREE.BoxGeometry(larg, alt, prof);
                const mesh = new THREE.Mesh(geo, materiais);
                mesh.position.set(x, y, z);
                if (interativo) objetosInterativos.push(mesh); // Adiciona na lista do Raycaster
                return mesh;
            }

            // 1. ESTRUTURA PRINCIPAL (Caixa)
            const grupoCaixa = new THREE.Group();
            
            // Base
            grupoCaixa.add(criarChapa(L - E*2, E, P, materiaisChapa, 0, E/2, 0));
            // Laterais
            grupoCaixa.add(criarChapa(E, A, P, materiaisChapa, -L/2 + E/2, A/2, 0));
            grupoCaixa.add(criarChapa(E, A, P, materiaisChapa, L/2 - E/2, A/2, 0));
            // Tampo Superior
            grupoCaixa.add(criarChapa(L - E*2, E, P, materiaisChapa, 0, A - E/2, 0));
            // Fundo (Recuado e mais fino)
            grupoCaixa.add(criarChapa(L - E*2, A - E*2, 0.006, materiaisChapa, 0, A/2, -P/2 + 0.01));

            grupoMovelAtual.add(grupoCaixa);

            // 2. CÁLCULO DE DIVISÃO (Gavetas em baixo, Portas em cima, ou vice-versa dependendo do móvel)
            // Lógica padrão: Gavetas ficam na base.
            let altGavetasTotal = 0;
            let altGavetaUnica = 0;
            
            if (numGavetas > 0) {
                altGavetasTotal = Math.min(A * 0.4, numGavetas * 0.25); // Max 40% da altura do móvel, ou 25cm por gaveta
                altGavetaUnica = altGavetasTotal / numGavetas;
                
                // Prateleira divisória acima das gavetas
                grupoCaixa.add(criarChapa(L - E*2, E, P - E, materiaisChapa, 0, E + altGavetasTotal + E/2, E/2));
            }

            // 3. CONSTRUIR GAVETAS INTERATIVAS
            if (numGavetas > 0) {
                const largGaveta = L - E*2 - F*2; // Largura livre menos folga
                const profGaveta = P - 0.05; // Gaveta não bate no fundo

                for (let i = 0; i < numGavetas; i++) {
                    const posY = E + (i * altGavetaUnica) + (altGavetaUnica / 2);
                    
                    const gavetaCorredica = new THREE.Group();
                    gavetaCorredica.position.set(0, posY, 0);
                    
                    // Frente da Gaveta (Interativa)
                    const altFrente = altGavetaUnica - F;
                    const frenteMesh = criarChapa(largura_mm < 600 ? largGaveta : largGaveta, altFrente, E, materiaisPorta, 0, 0, P/2 - E/2, true);
                    frenteMesh.userData.grupoPai = gavetaCorredica; // Link para o Raycaster saber quem animar
                    gavetaCorredica.add(frenteMesh);

                    // Puxador da Gaveta
                    const puxador = new THREE.Mesh(new THREE.CylinderGeometry(0.01, 0.01, 0.15, 16), matPuxador);
                    puxador.rotation.z = Math.PI / 2;
                    puxador.position.set(0, 0, P/2 + 0.02);
                    gavetaCorredica.add(puxador);

                    // Caixa Interna da Gaveta (Simplificada)
                    const largInt = largGaveta - 0.03; // Desconto das corrediças
                    const altInt = altFrente - 0.04;
                    gavetaCorredica.add(criarChapa(E, altInt, profGaveta - E, materiaisChapa, -largInt/2 + E/2, 0, P/2 - profGaveta/2 - E)); // Lateral Esq
                    gavetaCorredica.add(criarChapa(E, altInt, profGaveta - E, materiaisChapa, largInt/2 - E/2, 0, P/2 - profGaveta/2 - E));  // Lateral Dir
                    gavetaCorredica.add(criarChapa(largInt - E*2, E, profGaveta - E, materiaisChapa, 0, -altInt/2 + E/2, P/2 - profGaveta/2 - E)); // Fundo Interno

                    // Configuração da Animação
                    gavetaCorredica.userData = { tipo: 'gaveta', aberto: false, posFechada: 0, posAberta: profGaveta * 0.8 };
                    
                    grupoMovelAtual.add(gavetaCorredica);
                }
            }

            // 4. CONSTRUIR PORTAS INTERATIVAS (Pivotantes)
            const altPortasVao = A - E*2 - (numGavetas > 0 ? altGavetasTotal + E : 0);
            
            if (numPortas > 0 && altPortasVao > 0.1) {
                const altPorta = altPortasVao - F;
                const largPorta = (L - E*2 - (F * (numPortas + 1))) / numPortas;
                
                const inicioX = -L/2 + E + F + largPorta/2;
                const posYPorta = E + (numGavetas > 0 ? altGavetasTotal + E : 0) + altPorta/2;

                for (let i = 0; i < numPortas; i++) {
                    const centroX = inicioX + (i * (largPorta + F));
                    
                    // Lógica de abertura: metade da esquerda abre pra esquerda, metade da direita abre pra direita
                    const abreEsquerda = i < numPortas / 2;
                    
                    // O Pivot é a dobradiça imaginária
                    const pivotX = abreEsquerda ? centroX - largPorta/2 : centroX + largPorta/2;
                    const portaPivot = new THREE.Group();
                    portaPivot.position.set(pivotX, posYPorta, P/2 - E/2);
                    
                    // A malha deslocada em relação à dobradiça
                    const deslocamentoX = abreEsquerda ? largPorta/2 : -largPorta/2;
                    const portaMesh = criarChapa(largPorta, altPorta, E, materiaisPorta, deslocamentoX, 0, 0, true);
                    portaMesh.userData.grupoPai = portaPivot;
                    portaPivot.add(portaMesh);

                    // Puxador da Porta
                    const puxador = new THREE.Mesh(new THREE.CylinderGeometry(0.01, 0.01, 0.15, 16), matPuxador);
                    const posXpuxador = abreEsquerda ? deslocamentoX + largPorta/2 - 0.04 : deslocamentoX - largPorta/2 + 0.04;
                    puxador.position.set(posXpuxador, 0, E/2 + 0.02);
                    portaPivot.add(puxador);

                    // Configuração da Animação
                    portaPivot.userData = { 
                        tipo: 'porta', 
                        aberto: false, 
                        rotacaoFechada: 0, 
                        rotacaoAberta: abreEsquerda ? -Math.PI / 2 : Math.PI / 2 // Abre 90 graus
                    };

                    grupoMovelAtual.add(portaPivot);
                }
            }

            // Centraliza a Câmera e Ajusta Visão
            const maxDim = Math.max(L, A, P);
            camera3D.position.set(0, A * 1.5, maxDim * 2.2); 
            controles3D.target.set(0, A / 2, 0); 
            controles3D.update();

            document.getElementById('info3D').innerHTML = `<i class="fas fa-check-circle" style="color:var(--earth-green);"></i> Parametrizado: ${largura_mm}x${altura_mm}x${profundidade_mm}mm | ${numPortas} Pts | ${numGavetas} Gav`;
        }

        // ==========================================
        // CÁLCULO FINANCEIRO
        // ==========================================
        function transferirParaOrcamento() {
            document.getElementById('addItemSection').scrollIntoView({behavior: 'smooth'});
        }

        function calcularTotal() {
            const mat = parseFloat(document.getElementById('costMaterial').value) || 0;
            const mao = parseFloat(document.getElementById('costLabor').value) || 0;
            const fer = parseFloat(document.getElementById('costHardware').value) || 0;
            const out = parseFloat(document.getElementById('costOther').value) || 0;
            const margem = parseFloat(document.getElementById('profitMargin').value) || 0;

            const custoFabrica = mat + mao + fer + out;
            const precoVenda = custoFabrica / (1 - (margem / 100));

            document.getElementById('totalProjectCost').innerText = 
                new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(precoVenda);
        }

    </script>
